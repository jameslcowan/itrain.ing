# Install: copy to /etc/caddy/sites/ and import from Caddyfile.

olympiclift.ing, www.olympiclift.ing {
	root * /var/www/olympiclift.ing

	@spa path /app /app/* /program/* /program/* /p/* /p/*
	rewrite @spa /app.html

	header @spa X-Robots-Tag "noindex, nofollow, noarchive"

	encode gzip zstd
	file_server

	handle_errors {
		rewrite * /404.html
		file_server
	}
}
