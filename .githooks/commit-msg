#!/bin/sh
# Strip agent/device co-author injection before any commit is recorded.
MSG="$1"
[ -f "$MSG" ] || exit 0
sed -i '/^Co-authored-by: Cursor /d' "$MSG"
sed -i '/^Co-authored-by: cursor/d' "$MSG"
sed -i '/^Co-authored-by:.*cursoragent@cursor\.com/d' "$MSG"
while [ -s "$MSG" ] && [ -z "$(tail -1 "$MSG" | tr -d '\n\r')" ]; do sed -i '$d' "$MSG"; done
exit 0
